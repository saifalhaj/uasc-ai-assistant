# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6          # optional; defaults to claude-sonnet-4-6

# ── Embeddings ────────────────────────────────────────────────────────────────
COHERE_API_KEY=...

# ── Vector Store ──────────────────────────────────────────────────────────────
QDRANT_URL=https://<cluster-id>.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=...

# ── Database & Storage ────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...           # server-side only — never expose to browser
SUPABASE_ANON_KEY=eyJ...                   # safe for browser / Next.js public env

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000  # set to Render URL in production

# ── CORS (comma-separated, server only) ──────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://uasc-agent.vercel.app

# ── Eval harness ─────────────────────────────────────────────────────────────
API_URL=http://localhost:8000              # override for remote eval runs
